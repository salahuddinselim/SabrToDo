# NextAuth.js Configuration
# Generate a secret: `npx auth secret` or use any random 32+ char string
AUTH_SECRET=your_random_secret_here_change_this

# Google OAuth Credentials
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# 4. Copy the Client ID and Client Secret
AUTH_GOOGLE_ID=your_google_client_id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your_google_client_secret

# Google Sheets Configuration
# 1. Go to https://console.cloud.google.com → Create project → Enable Sheets API
# 2. Go to "Credentials" → Create Service Account → Download JSON key
# 3. Share your Google Sheet with the service account email as Editor
# 4. The sheet ID is the long string in the sheet URL: https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id

# Web Push (VAPID) — PWA push notifications
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
VAPID_PRIVATE_KEY=your_vapid_private_key_here

# Cron job secret — protects /api/cron/reminders from unauthorized access
CRON_SECRET=your_random_cron_secret_here
